{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@hueyexe/opencode-ensemble"],
  "agent": {
    "frontend-developer": {
      "description": "Especialista en frontend con Next.js, Tailwind y shadcn/ui",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.2,
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "write": "allow"
      }
    },
    "backend-developer": {
      "description": "Especialista en backend con Supabase, Clean Architecture y TypeScript",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.2,
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "write": "allow"
      }
    },
    "code-reviewer": {
      "description": "Revisor de código con foco en seguridad y mejores prácticas",
      "mode": "subagent",
      "model": "openai/gpt-4-turbo",
      "temperature": 0.1,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
        "read": "allow"
      }
    },
    "test-writer": {
      "description": "Escribe tests TDD para implementaciones",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-20250514",
      "temperature": 0.3,
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "write": "allow"
      }
    }
  },
  "formatter": {
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE"
      ],
      "environment": {
        "NODE_ENV": "development"
      },
      "extensions": [
        ".js",
        ".ts",
        ".jsx",
        ".tsx"
      ]
    },
    "custom-markdown-formatter": {
      "command": [
        "deno",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "websearch": "allow",
    "webfetch": "allow"
  },
  "provider": {
    "google": {
      "models": {
        "gemini-2.5-flash": {},
        "gemini-2.0-flash": {}
      }
    },
    "mistral": {
      "models": {
        "mistral-small-latest": {},
        "codestral-latest": {}
      }
    },
    "openrouter": {
      "models": {
        "deepseek/deepseek-chat-v3-0324": {
          "name": "DeepSeek V3"
        },
        "meta-llama/llama-3.3-70b-instruct": {
          "name": "Llama 3.3 70B"
        }
      }
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem"
      ],
      "enabled": true,
      "environment": {
        "ALLOWED_PATHS": "./src,./apps,./packages"
      }
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=",
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "supabase-local": {
      "type": "remote",
      "url": "http://127.0.0.1:54321/mcp",
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-linear"
      ],
      "enabled": true,
      "environment": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      }
    },
    "curl": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mcp-get-community/server-curl"
      ],
      "enabled": true
    }
  }
}