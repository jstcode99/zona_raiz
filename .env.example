# ===========================================
# zona_raiz - Environment Variables Template
# ===========================================
# Copy this to .env and fill in your values
# DO NOT commit .env to version control!

# -----------------------------
# Supabase Configuration
# -----------------------------
# Production Supabase URL (Kong proxy)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct PostgreSQL connection (for migrations)
SUPABASE_DB_URL=postgresql://postgres:your_password@postgres:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/postgres

# -----------------------------
# PostgreSQL (Docker self-hosted)
# -----------------------------
POSTGRES_PASSWORD=secure_postgres_password

# -----------------------------
# MinIO (S3-compatible storage)
# -----------------------------
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=secure_minio_password

# -----------------------------
# Google OAuth
# -----------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------
# Google Maps
# -----------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# -----------------------------
# hCaptcha
# -----------------------------
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET=your_hcaptcha_secret

# -----------------------------
# Logging & Monitoring
# -----------------------------
LOG_LEVEL=info

# -----------------------------
# Grafana Dashboard
# -----------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=secure_grafana_password

# -----------------------------
# Application (defaults)
# -----------------------------
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000