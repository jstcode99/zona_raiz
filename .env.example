# ============================================
# zona_raiz - Environment Variables Template
# ============================================
# Copy this to .env and fill in your values
# DO NOT commit .env to version control!

# -----------------------------
# PostgreSQL (Docker self-hosted)
# -----------------------------
POSTGRES_PASSWORD=secure_postgres_password_generate_strong
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# Direct PostgreSQL connection (for migrations)
SUPABASE_DB_URL=postgresql://postgres:secure_postgres_password_generate_strong@postgres:5432/postgres
DATABASE_URL=postgresql://postgres:secure_postgres_password_generate_strong@localhost:5432/postgres

# -----------------------------
# Supabase Configuration
# -----------------------------
# Generate with: openssl rand -base64 32
SUPABASE_JWT_SECRET=your_jwt_secret_min_32_chars_generate_with_openssl

# Anon key - public safe to expose
SUPABASE_ANON_KEY=your_anon_key_eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9_...

# Service role key - KEEP SECRET! Admin access
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9_...

# Production Supabase URL (Kong proxy)
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# -----------------------------
# MinIO (S3-compatible storage)
# -----------------------------
MINIO_ROOT_USER=minio_admin_generate_user
MINIO_ROOT_PASSWORD=secure_minio_password_generate_strong

# -----------------------------
# Google OAuth
# -----------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=943984157945-xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_from_google_cloud_console

# -----------------------------
# Google Maps
# -----------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_from_google_cloud_console

# -----------------------------
# hCaptcha (Optional - for production)
# -----------------------------
# Get from https://dashboard.hcaptcha.com/
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET=your_hcaptcha_secret_key

# -----------------------------
# Email (SMTP)
# -----------------------------
# Development: use Mailhog (already in docker-compose)
# Production: use Resend, SendGrid, AWS SES, etc.

# Mailhog (development)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Resend (production) - optional
# RESEND_API_KEY=re_123456789

# -----------------------------
# Logging & Monitoring
# -----------------------------
LOG_LEVEL=info
LOKI_ENDPOINT=http://loki:3100

# -----------------------------
# Grafana Dashboard
# -----------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=secure_grafana_password_generate

# -----------------------------
# Application
# -----------------------------
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://yourdomain.com  # Production

# -----------------------------
# Backup Configuration (optional)
# -----------------------------
BACKUP_DIR=/backups/postgres
RETENTION_DAYS=7

# -----------------------------
# Domain (Production)
# -----------------------------
# DOMAIN=yourdomain.com
# HTTPS=true  # Set up with Nginx + Let's Encrypt