{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./app/*"],
      "@/modules/*": ["./modules/*"],
      "@/assets/*": ["./assets/*"],
      "@/lib/*": ["./app/lib/*"],
      "@/infrastructure/*": ["./infrastructure/*"],
      "@/domain/*": ["./domain/*"],
      "@/features/*": ["./features/*"],
      "@/application/*": ["./application/*"],
      "@/shared/*": ["./shared/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "assets/svg/background-shape.sbvg"  ],
  "exclude": ["node_modules"]
}
