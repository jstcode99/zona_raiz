{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["google.maps"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next",
      },
    ],
    "paths": {
      "@/*": ["./app/*"],
      "@/modules/*": ["./modules/*"],
      "@/assets/*": ["./assets/*"],
      "@/lib/*": ["./app/lib/*"],
      "@/infrastructure/*": ["./infrastructure/*"],
      "@/interfaces/*": ["./interfaces/*"],
      "@/domain/*": ["./domain/*"],
      "@/features/*": ["./features/*"],
      "@/application/*": ["./application/*"],
      "@/config/*": ["./config/*"],
      "@/shared/*": ["./shared/*"],
      "@/i18n/*": ["./i18n/*"],
      "@/locales/*": ["./locales/*"],
    },
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.d.ts",
    "assets/svg/background-shape.svg"
  ],
  "exclude": ["node_modules"],
}
